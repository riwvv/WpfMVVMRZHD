<Page x:Class="WpfMVVMRZHD.Views.Pages.AdminSchedulePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfMVVMRZHD.Views.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="1000"
      Title="AdminSchedulePage">
    <Page.Resources>
        <Style x:Name="BtStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="MediumVioletRed" CornerRadius="10" Padding="10 5" Margin="5">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center" TextBlock.Foreground="WhiteSmoke" TextBlock.FontSize="18"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="Black"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>
    <Grid>
        <ListView ItemsSource="{Binding CurrentSchedule}" BorderBrush="Transparent">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Background="WhiteSmoke" CornerRadius="10" Padding="20 10" Margin="2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0 0 0 5" VerticalAlignment="Center">
                                <StackPanel Margin="0 0 0 5" Orientation="Horizontal">
                                    <TextBlock Text="От: "/>
                                    <TextBlock Text="{Binding Departure_station}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="До: "/>
                                    <TextBlock Text="{Binding Arrival_station}"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Margin="5 0" Grid.Column="1" VerticalAlignment="Center">
                                <StackPanel Margin="0 0 0 5" Orientation="Horizontal">
                                    <TextBlock Text="Дата отправления: "/>
                                    <TextBlock Text="{Binding Departure_date_time}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Дата прибытия: "/>
                                    <TextBlock Text="{Binding Arrival_date_time}"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Margin="5 0" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Свободных мест: "/>
                                <TextBlock Text="{Binding Number_of_available_seats}"/>
                            </StackPanel>
                            <StackPanel Margin="5 0" Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Цена: "/>
                                <TextBlock Text="{Binding Ticket_price, StringFormat={}{0:F2} руб.}"/>
                            </StackPanel>
                            <Button Margin="5 0 0 0" Grid.Column="4" Content="Купить" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>
    </Grid>
</Page>
