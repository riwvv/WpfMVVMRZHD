<Window x:Class="WpfMVVMRZHD.Views.Windows.LogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfMVVMRZHD.Views.Windows"
        mc:Ignorable="d"
        Title="LogWindow" Height="450" Width="800">
    <Grid>
        <Border Background="WhiteSmoke" CornerRadius="10" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="70 30">
            <StackPanel>
                <TextBlock Text="Вход" HorizontalAlignment="Center" FontSize="28" FontWeight="Medium" Margin="0 0 0 20"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Логин" Margin="0 0 10 0"/>
                    <TextBox Grid.Column="1" Text="{Binding Login}" MinWidth="100"/>
                    <TextBlock Grid.Row="1" Text="Пароль" Margin="0 0 10 0"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Password}" MinWidth="100"/>
                </Grid>
                <StackPanel Orientation="Horizontal" Margin="0 10 0 0">
                    <Button Command="{Binding AuthorizationCommand}" Content="Войти" Margin="0 0 10 0"/>
                    <Button Command="{Binding RegistrationCommand}" Content="Зарегистрироваться"/>
                </StackPanel>
                <TextBlock HorizontalAlignment="Center" Text="{Binding ErrorMessage}" Foreground="Red" FontSize="16"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
